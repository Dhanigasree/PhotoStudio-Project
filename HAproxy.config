apiVersion: v1
kind: ConfigMap
metadata:
  name: haproxy-config
  namespace: photostudio
data:
  haproxy.cfg: |
    global
        daemon
    defaults
        mode http
        timeout connect 5s
        timeout client 50s
        timeout server 50s

    frontend http_front
        bind *:80
        default_backend backend_servers

    backend backend_servers
        balance roundrobin
        server backend1 photostudio-backend-service:3000 check
